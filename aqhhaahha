-- ==================== TOGGLE STATES ====================
local freezeState = false
local autoState = false
local sureState = false

-- Para maiwasan ang bug (debounce)
local freezeDebounce = false
local autoDebounce = false
local sureDebounce = false

-- ==================== FUNCTION PARA MAGUPDATE NG SURETOGGLE VISIBILITY ====================
local function updateSureToggleVisibility()
    if autoState then
        sureToggleFrame.Visible = true
        -- I-adjust ang container height para magkasya
        toggleContainer.Size = UDim2.new(1, -32, 0, 140)
        mainFrame.Size = UDim2.new(0, 360, 0, 260)
    else
        sureToggleFrame.Visible = false
        -- I-reset ang sure state kapag nag-off ang auto accept
        if sureState then
            sureState = false
            TweenService:Create(sureToggle, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(55, 60, 70)}):Play()
            TweenService:Create(sureKnob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 3, 0.5, 0)}):Play()
        end
        toggleContainer.Size = UDim2.new(1, -32, 0, 100)
        mainFrame.Size = UDim2.new(0, 360, 0, 220)
    end
end

-- ==================== TOGGLE 1: FREEZE TRADE (FIXED - may debounce) ====================
local function toggleFreeze()
    if freezeDebounce then return end
    freezeDebounce = true
    
    freezeState = not freezeState
    local targetBg = freezeState and Color3.fromRGB(235, 75, 85) or Color3.fromRGB(55, 60, 70)
    local targetKnobPos = freezeState and 23 or 3
    
    TweenService:Create(freezeToggle, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = targetBg}):Play()
    TweenService:Create(freezeKnob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = UDim2.new(0, targetKnobPos, 0.5, 0)}):Play()
    
    task.wait(0.2)
    freezeDebounce = false
end

-- ==================== TOGGLE 2: AUTO ACCEPT (FIXED - may debounce at nagpapakita ng sure toggle) ====================
local function toggleAuto()
    if autoDebounce then return end
    autoDebounce = true
    
    autoState = not autoState
    local targetBg = autoState and Color3.fromRGB(70, 150, 200) or Color3.fromRGB(55, 60, 70)
    local targetKnobPos = autoState and 23 or 3
    
    TweenService:Create(autoToggle, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = targetBg}):Play()
    TweenService:Create(autoKnob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = UDim2.new(0, targetKnobPos, 0.5, 0)}):Play()
    
    -- Ipakita o itago ang "Auto Are U Sure" toggle
    updateSureToggleVisibility()
    
    task.wait(0.2)
    autoDebounce = false
end

-- ==================== TOGGLE 3: AUTO ARE U SURE ====================
local function toggleSure()
    if sureDebounce then return end
    sureDebounce = true
    
    sureState = not sureState
    local targetBg = sureState and Color3.fromRGB(235, 75, 85) or Color3.fromRGB(55, 60, 70)
    local targetKnobPos = sureState and 23 or 3
    
    TweenService:Create(sureToggle, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = targetBg}):Play()
    TweenService:Create(sureKnob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = UDim2.new(0, targetKnobPos, 0.5, 0)}):Play()
    
    task.wait(0.2)
    sureDebounce = false
end

